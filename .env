DATABASE_URL="postgresql://postgres:2348@178.105.188.193:5432/postgres"

# Server configurationv
NODE_ENV=development
PORT=8000

# JWT Authentication (Secret must be at least 32 characters)
JWT_SECRET=supersecretsecretkey12345678901234567890
JWT_EXPIRES_IN=168h

# CORS settings
CORS_ENABLED=true
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Security headers
HELMET_ENABLED=true

# Logging
LOG_LEVEL=info